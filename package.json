{
  "name": "discord-worker",
  "version": "1.0.0",
  "description": "Fun experiment with Cloudflare workers and a discord bot",
  "type": "module",
  "private": true,
  "engines": {
    "node": "26",
    "npm": "11"
  },
  "scripts": {
    "start": "wrangler dev --env dev --port 8787",
    "lint": "eslint . --ext .ts",
    "fix": "eslint --fix . --ext .ts",
    "check": "tsc --noEmit",
    "test": "vitest",
    "e2e": "vitest --config ./test/e2e/vitest.e2e.config.ts",
    "smoke": "bash ./scripts/run_smoke.sh",
    "deploy_commands": "tsx scripts/deploy_commands.ts",
    "generate_test_keys": "tsx scripts/generate_test_keys.ts",
    "publish:test": "wrangler deploy --env test",
    "publish:prod": "wrangler deploy --env prod"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "discord-api-types": "^0.38.47",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260111.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.58.0"
  }
}
