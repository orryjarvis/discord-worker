{
  "name": "discord-worker",
  "version": "1.0.0",
  "description": "Fun experiment with Cloudflare workers and a discord bot",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "wrangler dev --env dev --port 8787",
    "start:cli": "tsx src/apps/cli-local/main.ts",
    "lint": "eslint . --ext .ts",
    "fix": "eslint --fix . --ext .ts",
    "check": "tsc --noEmit",
    "test": "vitest",
    "e2e": "npm run e2e:discord-worker",
    "e2e:all": "npm run e2e:discord-worker && npm run e2e:cli-local",
    "e2e:discord-worker": "vitest --config ./test/e2e/vitest.e2e.config.ts",
    "e2e:cli-local": "vitest --config ./test/e2e/vitest.cli-local.e2e.config.ts",
    "smoke": "npm run smoke:discord-worker",
    "smoke:discord-worker": "vitest --config ./test/e2e/vitest.smoke.config.ts",
    "deploy_commands": "tsx scripts/deploy_commands.ts",
    "generate_test_keys": "tsx scripts/generate_test_keys.ts",
    "publish:test": "wrangler deploy --env test",
    "publish:prod": "wrangler deploy --env prod"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "discord-api-types": "^0.38.37",
    "itty-router": "^5.0.22",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260111.0",
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.58.0"
  }
}
